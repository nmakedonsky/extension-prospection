{
  "manifest_version": 3,
  "name": "Prospection",
  "version": "0.2.1",
  "description": "LinkedIn Jobs — badges SS2I / Client (Gemini), cache Supabase, HubSpot en option.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://*.supabase.co/*",
    "https://api.hubapi.com/*",
    "https://api-eu1.hubapi.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Prospection"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/*"
      ],
      "js": ["content/jobs-page.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
